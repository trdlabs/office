# Copy to deploy/.env — docker compose auto-loads it. Never commit deploy/.env.

# REQUIRED: enables operator auth. The web app prompts for this at sign-in;
# the server verifies it and issues a session token.
OFFICE_OPERATOR_PASSWORD=change-me

# Optional: pin a specific published build instead of :latest (e.g. sha-244d217).
# OFFICE_IMAGE_TAG=latest

# Optional: override only if you serve the web app from a non-default origin.
# Must equal the browser origin of the web app (CORS).
# OFFICE_CORS_ORIGIN=http://localhost:8080
