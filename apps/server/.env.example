# Copy this file to apps/server/.env — the server auto-loads it at startup
# (process.loadEnvFile). Ambient env / `docker run -e ...` always wins over it.
OFFICE_SERVER_PORT=8787
OFFICE_CORS_ORIGIN=http://localhost:5174
OFFICE_EVENT_TICK_MS=2600
OFFICE_HEARTBEAT_MS=15000
OFFICE_FIXTURE_LATENCY_MS=220

# Operator auth (server-only). Auth is ENFORCED only when a password is set;
# leave OFFICE_OPERATOR_PASSWORD empty/unset to keep the API open (dev/demo).
# When set, every /api/office/* route + the WS upgrade requires a session token
# issued by POST /api/office/operator/login.
OFFICE_OPERATOR_PASSWORD=
OFFICE_AUTH_SECRET=                        # HMAC key for session tokens; defaults to the password
OFFICE_AUTH_TTL_MS=43200000               # session lifetime (default 12h)

# Phase 3 — trading-lab integration (server-only; NEVER expose to the browser)
OFFICE_CONNECTOR_MODE=fixture            # fixture | trading-lab
TRADING_LAB_READ_URL=http://localhost:3100
TRADING_LAB_READ_TOKEN=
TRADING_LAB_CHAT_URL=http://localhost:3000
TRADING_LAB_CHAT_TOKEN=
# chat-follow guards (optional)
OFFICE_CHAT_FOLLOW_MAX_MS=300000
OFFICE_CHAT_FOLLOW_IDLE_MS=45000
OFFICE_CHAT_FOLLOW_MAX_DELTAS=200
OFFICE_CHAT_BOOTSTRAP_RETRIES=8
OFFICE_CHAT_BOOTSTRAP_INTERVAL_MS=750
OFFICE_STREAM_RECONNECT_BASE_MS=1000
OFFICE_STREAM_RECONNECT_MAX_MS=30000
