# Скопируй в apps/server/.env — сервер сам подхватит файл на старте (process.loadEnvFile).
# Ambient env / `docker run -e ...` всегда важнее файла.
# Файл сгенерирован из apps/server/src/env.ts — не править руками, запусти `npm run env:docs`.

# HMAC-ключ подписи сессионных токенов оператора; не задан — используется OFFICE_OPERATOR_PASSWORD
# secret — значение в SOPS/age-контуре, см. b2c-ops-hardening item 3
OFFICE_AUTH_SECRET=

# Время жизни сессионного токена оператора, мс (по умолчанию 12 часов)
OFFICE_AUTH_TTL_MS=43200000

# Интервал между попытками получить summary завершившегося downstream-бэктеста, мс
OFFICE_BACKTEST_SUMMARY_INTERVAL_MS=500

# Число попыток получить summary завершившегося downstream-бэктеста
OFFICE_BACKTEST_SUMMARY_RETRIES=5

# Idle-гард наблюдателя downstream-бэктестов: стоп после стольких мс без новых событий
OFFICE_BACKTEST_WATCH_IDLE_MS=120000

# Максимальная длительность наблюдения за downstream-бэктестами, мс
OFFICE_BACKTEST_WATCH_MAX_MS=900000

# Интервал между bootstrap-попытками чата/наблюдателей (первое чтение ленты событий), мс
OFFICE_CHAT_BOOTSTRAP_INTERVAL_MS=750

# Число bootstrap-попыток чата/наблюдателей (первое чтение ленты событий)
OFFICE_CHAT_BOOTSTRAP_RETRIES=8

# Idle-гард follow-режима оператор-чата: стоп после стольких мс без новых дельт
OFFICE_CHAT_FOLLOW_IDLE_MS=45000

# Максимум дельт, которые follow-режим оператор-чата ретранслирует за один запуск
OFFICE_CHAT_FOLLOW_MAX_DELTAS=200

# Максимальная длительность follow-режима оператор-чата, мс
OFFICE_CHAT_FOLLOW_MAX_MS=300000

# Режим коннектора офиса: fixture (демо-данные, standalone) или trading-lab (connected, live-чтение лаборатории)
# Допустимо: fixture | trading-lab
OFFICE_CONNECTOR_MODE=fixture

# Разрешённый CORS-origin веб-офиса; обязан совпадать с origin, с которого браузер грузит web-приложение
OFFICE_CORS_ORIGIN=http://localhost:5174

# Период тика fixture-продьюсера офисных событий, мс
OFFICE_EVENT_TICK_MS=2600

# Искусственная задержка ответов fixture-коннектора (демо реалистичной сети), мс
OFFICE_FIXTURE_LATENCY_MS=0

# Период heartbeat-события в WebSocket-потоке офиса, мс
OFFICE_HEARTBEAT_MS=15000

# Пароль оператора: включает auth на /api/office/* и WS. В connected-режиме (OFFICE_CONNECTOR_MODE=trading-lab и/или OFFICE_PLATFORM_ENABLED=true) обязателен — сервер отказывается стартовать без него (fail-closed гейт SEC-O1 в loadConfig); standalone (fixture) без него легален
# secret — значение в SOPS/age-контуре, см. b2c-ops-hardening item 3
OFFICE_OPERATOR_PASSWORD=

# Мониторинг trading-platform в офисе; действует только в режиме trading-lab и требует TRADING_PLATFORM_READ_URL/TOKEN
OFFICE_PLATFORM_ENABLED=false

# Интервал между bootstrap-попытками scorecard-фолловера, мс
OFFICE_SCORECARD_BOOTSTRAP_INTERVAL_MS=750

# Число bootstrap-попыток scorecard-фолловера
OFFICE_SCORECARD_BOOTSTRAP_RETRIES=8

# Интервал между попытками скачать markdown цикл-скоркарда, мс
OFFICE_SCORECARD_FETCH_INTERVAL_MS=500

# Число попыток скачать markdown цикл-скоркарда
OFFICE_SCORECARD_FETCH_RETRIES=3

# TTL наблюдения scorecard-фолловера за cycle-run, мс
OFFICE_SCORECARD_TTL_MS=3600000

# Порт HTTP/WS office-server
OFFICE_SERVER_PORT=8787

# Базовая задержка экспоненциального reconnect-бэккофа стрима лаборатории, мс
OFFICE_STREAM_RECONNECT_BASE_MS=1000

# Потолок reconnect-бэккофа стрима лаборатории, мс
OFFICE_STREAM_RECONNECT_MAX_MS=30000

# Публиковать completion-summary задач лаборатории в оператор-чат (по умолчанию включено)
OPERATOR_COMPLETION_SUMMARY=true

# Публиковать cycle-скоркард лаборатории в оператор-чат (R5d); действует только в режиме trading-lab
OPERATOR_CYCLE_SCORECARD=false

# Следить за downstream-бэктестами cycle-run и публиковать их summary в оператор-чат; действует только в режиме trading-lab
OPERATOR_DOWNSTREAM_BACKTESTS=false

# Сервисный токен чат-API trading-lab (прокси оператор-чата); без него connected-офис работает без чата
# secret — значение в SOPS/age-контуре, см. b2c-ops-hardening item 3
TRADING_LAB_CHAT_TOKEN=

# Базовый URL чат-API trading-lab
TRADING_LAB_CHAT_URL=http://localhost:3000

# Сервисный токен read-API trading-lab; в режиме trading-lab обязателен (гейт в loadConfig)
# secret — значение в SOPS/age-контуре, см. b2c-ops-hardening item 3
TRADING_LAB_READ_TOKEN=

# Базовый URL read-API trading-lab; в режиме trading-lab обязан быть задан явно (гейт в loadConfig)
TRADING_LAB_READ_URL=http://localhost:3100

# Таймаут HTTP-запросов офиса к trading-lab, мс
TRADING_LAB_REQUEST_TIMEOUT_MS=10000

# Сервисный ops-read токен trading-platform; при OFFICE_PLATFORM_ENABLED=true обязателен (гейт в loadConfig)
# secret — значение в SOPS/age-контуре, см. b2c-ops-hardening item 3
TRADING_PLATFORM_READ_TOKEN=

# Базовый URL ops-read API trading-platform; при включённом мониторинге обязан быть задан явно (гейт в loadConfig)
TRADING_PLATFORM_READ_URL=http://localhost:8839

# Таймаут HTTP-запросов офиса к trading-platform, мс
TRADING_PLATFORM_REQUEST_TIMEOUT_MS=10000
