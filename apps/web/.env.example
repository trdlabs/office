# Build-time переменные веб-офиса (vite, import.meta.env). Скопируй в apps/web/.env.
# Для connected-режима см. закоммиченный apps/web/.env.connected (vite --mode connected).
# Файл сгенерирован из apps/server/src/env.ts — не править руками, запусти `npm run env:docs`.

# Build-time (vite): базовый HTTP-URL office-server для connected-веба
VITE_OFFICE_GATEWAY_URL=http://localhost:8787

# Build-time (vite): WS-URL office-server; не задан — шлюз выводит его из VITE_OFFICE_GATEWAY_URL
# VITE_OFFICE_GATEWAY_WS_URL=

# Build-time (vite): режим веб-офиса — mock (fixtures в браузере) или connected (live-шлюз office-server)
# Допустимо: mock | connected
VITE_OFFICE_MODE=mock
